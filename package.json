{
	"name": "astro-html-kit",
	"version": "0.3.2",
	"description": "Astro integration and middleware to clean up your HTML.",
	"keywords": [
		"astro",
		"astro-integration",
		"astro-component",
		"html",
		"middleware",
		"dom",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/astro-html-kit",
	"bugs": "https://github.com/kitschpatrol/astro-html-kit/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/astro-html-kit.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./middleware": "./src/middleware.ts"
	},
	"files": [
		"src"
	],
	"scripts": {
		"build": "pnpm astro sync && pnpm run -r astro sync",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "pnpm run play",
		"fix": "ksc fix",
		"lint": "ksc lint && pnpm run -r --include-workspace-root astro check",
		"play": "pnpm -C playground run dev",
		"play-starlight": "pnpm -C playground-starlight run dev",
		"release": "bumpp --commit 'Release: %s' && pnpm build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') pnpm publish",
		"test": "vitest run"
	},
	"dependencies": {
		"linkedom": "^0.18.12"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@kitschpatrol/shared-config": "^7.6.3",
		"@types/node": "~24.12.4",
		"astro": "^6.4.4",
		"bumpp": "^11.1.0",
		"node-addon-api": "^8.8.0",
		"node-gyp": "^12.3.0",
		"shx": "^0.4.0",
		"typescript": "~5.9.3",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"astro": "^6.4.0"
	},
	"packageManager": "pnpm@11.5.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24.12.0"
		}
	}
}
